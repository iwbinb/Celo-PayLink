{
  "name": "celo-paylink",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "pages:dev": "npm run build && wrangler pages dev dist --compatibility-date=2026-06-11 --d1 DB=celo-paylink-db",
    "d1:create": "wrangler d1 create celo-paylink-db",
    "d1:migrate:local": "wrangler d1 migrations apply celo-paylink-db --local",
    "d1:migrate:remote": "wrangler d1 migrations apply celo-paylink-db --remote",
    "deploy": "npm run build && wrangler pages deploy dist --project-name=celo-paylink"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "lucide-react": "^0.468.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260611.0",
    "@types/node": "^22.10.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.7.2",
    "wrangler": "^4.20.0"
  }
}
